{
  "name": "aitask",
  "version": "0.1.0",
  "description": "CLI for managing tasks with template support",
  "main": "./dist/index.js",
  "bin": {
    "aitask": "./dist/aitask.cjs"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc && node scripts/sync-bin.js",
    "test": "node node_modules/jest/bin/jest.js",
    "lint": "eslint src/**/*.ts test/**/*.ts",
    "format": "prettier --write src/**/*.ts test/**/*.ts",
    "format:check": "prettier --check src/**/*.ts test/**/*.ts",
    "adr_contract:check": "node scripts/check-adr-contract.mjs"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/node": "22.15.21",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "8.57.1",
    "jest": "30.3.0",
    "prettier": "3.8.3",
    "ts-jest": "29.4.0",
    "typescript": "5.9.3"
  }
}
